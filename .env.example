# Frontend
VITE_AEGIS_API_URL=/api

# API server
AEGIS_PORT=8787
AEGIS_SERVER_URL=http://localhost:8787
AEGIS_WALLET_PROVIDER=demo
AEGIS_REASONING_PROVIDER=deterministic
AEGIS_NETWORK_NAME=Ethereum Sepolia
AEGIS_EXPLORER_BASE_URL=https://sepolia.etherscan.io
AEGIS_SCHEDULER_ENABLED=true
AEGIS_SCHEDULER_INTERVAL_MS=60000
AEGIS_SCHEDULER_RUN_ON_START=false

# Optional OpenAI-compatible reasoning mode
# Supports OpenAI directly or providers with OpenAI-compatible Responses APIs
OPENAI_API_KEY=
AEGIS_OPENAI_MODEL=gpt-5-mini
AEGIS_OPENAI_MODELS=
AEGIS_OPENAI_BASE_URL=https://api.openai.com/v1

# WDK live mode
# Switch AEGIS_WALLET_PROVIDER to "wdk" to enable these.
AEGIS_WALLET_SEED_PHRASE=
AEGIS_EVM_RPC_URL=
AEGIS_USDT_TOKEN_ADDRESS=
AEGIS_TOKEN_DECIMALS=6
AEGIS_TRANSFER_MAX_FEE_WEI=

# Telegram bot
TELEGRAM_BOT_TOKEN=
