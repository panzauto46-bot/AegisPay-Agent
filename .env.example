# Frontend
VITE_AEGIS_API_URL=/api
# Optional: required when backend API auth is enabled
VITE_AEGIS_API_KEY=

# API server
AEGIS_PORT=8787
AEGIS_SERVER_URL=http://localhost:8787
AEGIS_WALLET_PROVIDER=demo
AEGIS_REASONING_PROVIDER=deterministic
AEGIS_NETWORK_NAME=Ethereum Sepolia
AEGIS_EXPLORER_BASE_URL=https://sepolia.etherscan.io
AEGIS_SCHEDULER_ENABLED=true
AEGIS_SCHEDULER_INTERVAL_MS=60000
AEGIS_SCHEDULER_RUN_ON_START=false
# Optional API auth (applies to /api except health/runtime/cron)
AEGIS_API_KEY=
# CORS allowlist (comma-separated). In production default is restricted, in dev default is *
AEGIS_ALLOWED_ORIGINS=
# Runtime state persistence
AEGIS_STATE_PERSISTENCE_ENABLED=true
# Default local: .data/agent-state.json, default Vercel: /tmp/aegispay-agent-state.json
AEGIS_STATE_FILE_PATH=
# Optional: protect /api/scheduler/cron (also used by Vercel Cron)
CRON_SECRET=

# Optional OpenAI-compatible reasoning mode
# Supports OpenAI directly or providers with OpenAI-compatible Responses APIs
OPENAI_API_KEY=
AEGIS_OPENAI_MODEL=gpt-5-mini
AEGIS_OPENAI_MODELS=
AEGIS_OPENAI_BASE_URL=https://api.openai.com/v1

# Optional OpenClaw reasoning mode
# Set AEGIS_REASONING_PROVIDER=openclaw to use local OpenClaw CLI
AEGIS_OPENCLAW_COMMAND=openclaw
AEGIS_OPENCLAW_TIMEOUT_MS=15000
AEGIS_OPENCLAW_SESSION_ID=aegispay
AEGIS_OPENCLAW_LOCAL=true
AEGIS_OPENCLAW_THINKING=high

# WDK live mode
# Switch AEGIS_WALLET_PROVIDER to "wdk" to enable these.
AEGIS_WALLET_SEED_PHRASE=
AEGIS_EVM_RPC_URL=
AEGIS_USDT_TOKEN_ADDRESS=
AEGIS_TOKEN_DECIMALS=6
AEGIS_TRANSFER_MAX_FEE_WEI=
# Optional: funded WDK smoke verification flags
AEGIS_WDK_SMOKE_EXECUTE=false
AEGIS_WDK_SMOKE_AMOUNT=0.01
AEGIS_WDK_SMOKE_RECIPIENT=

# Optional: deployed runtime smoke verification
AEGIS_DEPLOYMENT_URL=
AEGIS_EXPECTED_WALLET_PROVIDER=
AEGIS_EXPECTED_REASONING_PROVIDER=

# Telegram bot
TELEGRAM_BOT_TOKEN=
